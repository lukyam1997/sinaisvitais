<script>
// Variáveis globais otimizadas
let currentUser = null;
let debounceTimer = null;

// Função auxiliar para mapear tipo para ID correto
function mapTipoToId(tipo) {
    switch (tipo.toUpperCase()) {
        case 'ADM': return 'admin';
        case 'TECNICO': return 'tecnico';
        case 'MEDICO': return 'medico';
        default: return tipo.toLowerCase();
    }
}

// Inicialização otimizada
document.addEventListener('DOMContentLoaded', function() {
    // Event listeners principais
    document.getElementById('esqueciSenhaLink').addEventListener('click', showRecuperarSenha);
    document.getElementById('voltarLogin').addEventListener('click', showLogin);

    // Logouts
    ['adminLogout', 'tecnicoLogout', 'medicoLogout'].forEach(id => {
        document.getElementById(id)?.addEventListener('click', logout);
    });

    // Formulários
    document.getElementById('loginForm')?.addEventListener('submit', handleLogin);
    document.getElementById('recuperarSenhaForm')?.addEventListener('submit', handleRecuperarSenha);
    document.getElementById('formCadastroUsuario')?.addEventListener('submit', handleCadastroUsuario);
    document.getElementById('formNovoCargo')?.addEventListener('submit', handleNovoCargo);
    document.getElementById('formRegistroPaciente')?.addEventListener('submit', handleRegistroPaciente);

    // Buscas
    document.getElementById('btnBuscarPaciente')?.addEventListener('click', () => handleBuscarPaciente('medico'));
    document.getElementById('btnBuscarPacienteAdmin')?.addEventListener('click', () => handleBuscarPaciente('admin'));
    document.getElementById('btnBuscarPacienteTecnico')?.addEventListener('click', () => handleBuscarPaciente('tecnico'));

    // Relatórios admin
    document.getElementById('gerarRelatorio')?.addEventListener('click', gerarRelatorioAdmin);

    // Tabs
    document.querySelectorAll('.tab-button').forEach(button => {
        button.addEventListener('click', function() {
            const tabId = this.getAttribute('data-tab');
            switchTab(tabId);
        });
    });

    // Notificação
    document.getElementById('closeNotification').addEventListener('click', hideNotification);

    // Carregamentos iniciais
    if (document.getElementById('setorUsuario')) loadSetores();
    if (document.getElementById('listaUsuarios')) loadUsuarios();
    if (document.getElementById('listaSetores')) loadSetoresList();

    // Dashboard médico
    if (document.getElementById('todaysOverview')) loadTodaysOverview();

    // Dashboard admin
    if (document.getElementById('dashboardAdmin')) loadDashboardAdmin();

    // Partículas
    createParticles();

    // Debounce para buscas
    ['buscaProntuario', 'buscaProntuarioAdmin', 'buscaProntuarioTecnico'].forEach(id => {
        document.getElementById(id)?.addEventListener('input', debounceSearch);
    });

    // Verificação inicial de login (para depuração)
    console.log('Página carregada. Login page deve estar visível.');
});

// Debounce para buscas em tempo real
function debounceSearch(e) {
    clearTimeout(debounceTimer);
    debounceTimer = setTimeout(() => {
        // Implementar busca em tempo real se necessário
    }, 500);
}

// Navegação
function showPage(pageId) {
    document.querySelectorAll('.page').forEach(page => page.classList.remove('active'));
    const targetPage = document.getElementById(pageId);
    if (targetPage) {
        targetPage.classList.add('active');
    } else {
        console.error('Página não encontrada: ' + pageId); // Debug
        showNotification('Erro: Página não encontrada. Recarregue a página.', 'error');
    }
}

function showLogin() { showPage('loginPage'); }
function showRecuperarSenha() { showPage('recuperarSenhaPage'); }

function switchTab(tabId) {
    document.querySelectorAll('.tab-button').forEach(btn => btn.classList.remove('active'));
    document.querySelectorAll('.tab-content').forEach(content => content.classList.remove('active'));

    const tabButton = document.querySelector(`[data-tab="${tabId}"]`);
    const tabContent = document.getElementById(tabId);
    if (tabButton) tabButton.classList.add('active');
    if (tabContent) tabContent.classList.add('active');
    else console.error('Tab não encontrada: ' + tabId); // Debug

    // Carregamentos específicos
    if (tabId === 'dashboardAdmin') loadDashboardAdmin();
    if (tabId === 'consultaPacientesAdmin') {} // Já carrega na busca
    if (tabId === 'gerenciarCargos') loadSetoresList();
}

// Login otimizado
function handleLogin(e) {
    e.preventDefault();
    const matricula = document.getElementById('matricula').value.trim();
    const senha = document.getElementById('senha').value;

    if (!matricula || !senha) {
        showNotification('Preencha todos os campos', 'error');
        return;
    }

    showLoading(true);

    google.script.run
        .withSuccessHandler(handleLoginSuccess)
        .withFailureHandler(err => {
            showNotification('Erro de conexão: ' + err.message, 'error');
            showLoading(false);
        })
        .fazerLogin(matricula, senha);
}

function handleLoginSuccess(result) {
    try {
        showLoading(false);
        if (result.success) {
            currentUser = result.user;
            const mappedTipo = mapTipoToId(currentUser.tipo);
            const pageId = mappedTipo + 'Page';
            const userNameId = mappedTipo + 'UserName';

            console.log('Debug: Mapeando tipo ' + currentUser.tipo + ' para ' + mappedTipo + ', página: ' + pageId); // Debug

            const userNameEl = document.getElementById(userNameId);
            if (userNameEl) {
                userNameEl.textContent = currentUser.nome;
            } else {
                console.error('Debug: Elemento não encontrado: ' + userNameId);
            }

            showPage(pageId);

            // Carregamentos pós-login
            if (mappedTipo === 'admin') {
                loadDashboardAdmin();
                loadUsuarios();
                loadSetoresList();
            } else if (mappedTipo === 'medico') {
                loadTodaysOverview();
            } else if (mappedTipo === 'tecnico') {
                // Carregamentos para técnico se necessário
            }

            showNotification(`Bem-vindo, ${currentUser.nome}!`, 'success');
        } else {
            showNotification(result.message, 'error');
            document.getElementById('loginForm').reset();
        }
    } catch (err) {
        console.error('Erro no handleLoginSuccess:', err);
        showNotification('Erro interno após login: ' + err.message, 'error');
        showLoading(false);
    }
}

// Recuperação de senha
function handleRecuperarSenha(e) {
    e.preventDefault();
    const matricula = document.getElementById('matriculaRecuperar').value.trim();

    if (!matricula) {
        showNotification('Digite uma matrícula válida', 'error');
        return;
    }

    showLoading(true);

    google.script.run
        .withSuccessHandler(result => {
            showLoading(false);
            showNotification(result.message, 'success');
            setTimeout(showLogin, 3000);
        })
        .withFailureHandler(err => {
            showLoading(false);
            showNotification('Erro: ' + err.message, 'error');
        })
        .recuperarSenha(matricula);
}

// Cadastro usuário
function handleCadastroUsuario(e) {
    e.preventDefault();
    const formData = {
        nome: document.getElementById('nomeCompleto').value.trim(),
        matricula: document.getElementById('matriculaUsuario').value.trim(),
        setor: document.getElementById('setorUsuario').value,
        senha: document.getElementById('senhaUsuario').value
    };

    if (!formData.nome || !formData.matricula || !formData.setor || !formData.senha) {
        showNotification('Preencha todos os campos', 'error');
        return;
    }

    showLoading(true);

    google.script.run
        .withSuccessHandler(result => {
            showLoading(false);
            showNotification(result.message, 'success');
            document.getElementById('formCadastroUsuario').reset();
            loadUsuarios();
        })
        .withFailureHandler(err => {
            showLoading(false);
            showNotification('Erro: ' + err.message, 'error');
        })
        .cadastrarUsuario(formData.nome, formData.matricula, formData.setor, formData.senha);
}

// Novo cargo
function handleNovoCargo(e) {
    e.preventDefault();
    const novoCargo = document.getElementById('novoCargo').value.trim();
    const nivelAcesso = document.getElementById('nivelAcesso').value;

    if (!novoCargo) {
        showNotification('Digite um nome para o setor', 'error');
        return;
    }

    showLoading(true);

    google.script.run
        .withSuccessHandler(result => {
            showLoading(false);
            showNotification(result.message, 'success');
            document.getElementById('formNovoCargo').reset();
            loadSetores();
            loadSetoresList();
        })
        .withFailureHandler(err => {
            showLoading(false);
            showNotification('Erro: ' + err.message, 'error');
        })
        .adicionarSetor(novoCargo, parseInt(nivelAcesso));
}

// Registro paciente
function handleRegistroPaciente(e) {
    e.preventDefault();
    const dados = {
        nomeCompleto: document.getElementById('nomePaciente').value.trim(),
        prontuario: document.getElementById('prontuario').value.trim(),
        dataNascimento: document.getElementById('dataNascimento').value,
        peso: document.getElementById('peso').value,
        altura: document.getElementById('altura').value,
        pressaoArterial: document.getElementById('pressaoArterial').value.trim(),
        temperatura: document.getElementById('temperatura').value,
        saturacao: document.getElementById('saturacao').value,
        glicemia: document.getElementById('glicemia').value,
        observacoes: document.getElementById('observacoes').value.trim()
    };

    if (!dados.nomeCompleto || !dados.prontuario || !dados.dataNascimento || !dados.peso || !dados.altura || !dados.pressaoArterial || !dados.temperatura) {
        showNotification('Preencha os campos obrigatórios (*)', 'error');
        return;
    }

    showLoading(true);

    google.script.run
        .withSuccessHandler(result => {
            showLoading(false);
            showNotification(result.message, 'success');
            document.getElementById('formRegistroPaciente').reset();
            if (currentUser && currentUser.tipo === 'TECNICO') loadTodaysOverview(); // Atualizar visão de hoje se aplicável
        })
        .withFailureHandler(err => {
            showLoading(false);
            showNotification('Erro: ' + err.message, 'error');
        })
        .registrarDadosPaciente(dados);
}

// Busca genérica para diferentes painéis - COM MAIS LOGS
function handleBuscarPaciente(tipo) {
    const inputId = tipo === 'medico' ? 'buscaProntuario' : tipo === 'admin' ? 'buscaProntuarioAdmin' : 'buscaProntuarioTecnico';
    const prontuario = document.getElementById(inputId).value.trim();

    console.log('🔍 HANDLE BUSCA:', { tipo, inputId, prontuario });

    if (!prontuario) {
        showNotification('Digite um número de prontuário', 'error');
        return;
    }

    showLoading(true);

    google.script.run
        .withSuccessHandler((registros) => {
            console.log('✅ SUCESSO na busca - Registros:', registros);
            showLoading(false);
            displayHistoricoPaciente(registros, tipo);
        })
        .withFailureHandler((err) => {
            console.error('❌ ERRO na busca:', err);
            showLoading(false);
            showNotification('Erro ao buscar: ' + err.message, 'error');
        })
        .buscarPaciente(prontuario);
}

// DISPLAY HISTORICO PACIENTE - VERSÃO À PROVA DE NULL
function displayHistoricoPaciente(registros, tipo) {
    console.log('🎨 DISPLAY: Iniciando exibição visual...');
    console.log('Registros recebidos:', registros);
    
    // CORREÇÃO CRÍTICA: Se for null, converter para array vazio
    if (registros === null) {
        console.log('⚠️  Registros é null, convertendo para array vazio');
        registros = [];
    }
    
    const suffix = tipo === 'admin' ? 'Admin' : tipo === 'tecnico' ? 'Tecnico' : '';
    const resultadoId = `resultadoBusca${suffix}`;
    const historicoId = `historicoPaciente${suffix}`;
    const resultadoEl = document.getElementById(resultadoId);
    const historicoEl = document.getElementById(historicoId);

    if (!resultadoEl || !historicoEl) {
        console.error('❌ Elementos não encontrados:', { resultadoId, historicoId });
        showNotification('Erro: Elementos da página não carregados', 'error');
        return;
    }

    if (registros.length === 0) {
        console.log('❌ Nenhum registro para exibir');
        showNotification('Nenhum registro encontrado para este prontuário', 'error');
        resultadoEl.classList.add('hidden');
        return;
    }

    // Info paciente
    const first = registros[0];
    console.log('Primeiro registro:', first);
    
    // CORREÇÃO: Buscar elementos DENTRO do container
    const nomeEl = document.getElementById(`nomePacienteBusca${suffix}`);
    const prontuarioEl = document.getElementById(`prontuarioBusca${suffix}`);
    const nascimentoEl = document.getElementById(`nascimentoBusca${suffix}`);
    
    if (nomeEl) nomeEl.textContent = first.nome || 'Nome não informado';
    if (prontuarioEl) prontuarioEl.textContent = first.prontuario || 'Não informado';
    if (nascimentoEl) nascimentoEl.textContent = formatDate(first.dataNascimento) || 'Não informado';

    // Histórico
    historicoEl.innerHTML = '';
    
    registros.forEach((registro, index) => {
        const isRecente = index === 0;
        const historicoItem = document.createElement('div');
        historicoItem.className = `historico-item ${isRecente ? 'recente' : ''}`;

        historicoItem.innerHTML = `
            <div class="historico-header">
                <h4><i class="fas fa-clock"></i> ${formatDateTime(registro.dataRegistro)}</h4>
                <p><i class="fas fa-user"></i> ${registro.usuarioRegistro || 'Sistema'} | <i class="fas fa-note-sticky"></i> ${registro.observacoes || 'Sem observações'}</p>
            </div>
            <div class="vitals-display">
                <div class="vital-item">
                    <div class="vital-value">${registro.peso || '-'} kg</div>
                    <div class="vital-label"><i class="fas fa-weight"></i> Peso</div>
                </div>
                <div class="vital-item">
                    <div class="vital-value">${registro.altura || '-'} cm</div>
                    <div class="vital-label"><i class="fas fa-ruler-vertical"></i> Altura</div>
                </div>
                <div class="vital-item">
                    <div class="vital-value">${registro.pressaoArterial || '-'}</div>
                    <div class="vital-label"><i class="fas fa-heart"></i> Pressão</div>
                </div>
                <div class="vital-item">
                    <div class="vital-value">${registro.temperatura || '-'} °C</div>
                    <div class="vital-label"><i class="fas fa-thermometer-half"></i> Temp.</div>
                </div>
                <div class="vital-item">
                    <div class="vital-value">${registro.saturacao || '-'}%</div>
                    <div class="vital-label"><i class="fas fa-lungs"></i> Sat. O₂</div>
                </div>
                <div class="vital-item">
                    <div class="vital-value">${registro.glicemia || '-'} mg/dL</div>
                    <div class="vital-label"><i class="fas fa-vial"></i> Glicemia</div>
                </div>
            </div>
        `;

        historicoEl.appendChild(historicoItem);
    });

    // MOSTRAR O CONTAINER
    resultadoEl.classList.remove('hidden');
    console.log('✅ Container de resultados VISÍVEL');
    
    showNotification(`Encontrados ${registros.length} registro(s)`, 'success');
}
