// BUSCAR PACIENTE - VERSÃO CORRIGIDA PARA TODOS OS FORMATOS
// BUSCAR PACIENTE - VERSÃO QUE NUNCA RETORNA NULL
function buscarPaciente(prontuario) {
  try {
    console.log('=== BUSCA INICIADA ===');
    console.log('Prontuário:', prontuario);
    
    const ss = getPlanilha();
    const sheet = ss.getSheetByName('BASE');
    
    if (!sheet) {
      console.log('Aba BASE não encontrada');
      return []; // SEMPRE retorna array, nunca null
    }

    const data = sheet.getDataRange().getValues();
    const registros = [];
    
    const prontuarioBusca = normalizarParaBusca(prontuario);
    console.log('Buscando (normalizado):', prontuarioBusca);

    for (let i = 1; i < data.length; i++) {
      const prontuarioPlanilha = String(data[i][1] || '').trim().toLowerCase();
      const prontuarioPlanilhaNormalizado = normalizarParaBusca(data[i][1]);
      const nomePaciente = data[i][0];

      console.log(
        `Linha ${i + 1}: "${nomePaciente}" - Pront: "${prontuarioPlanilha}" (normalizado: "${prontuarioPlanilhaNormalizado}")`
      );

      if (compararProntuarios(prontuarioPlanilhaNormalizado, prontuarioBusca)) {
        console.log('✅ REGISTRO ENCONTRADO!');
        registros.push({
          nome: data[i][0] || '',
          prontuario: data[i][1] || '',
          dataNascimento: data[i][2] || '',
          peso: data[i][3] || '',
          altura: data[i][4] || '',
          pressaoArterial: data[i][5] || '',
          temperatura: data[i][6] || '',
          saturacao: data[i][7] || '',
          glicemia: data[i][8] || '',
          dataRegistro: data[i][9] || '',
          usuarioRegistro: data[i][10] || '',
          observacoes: data[i][11] || ''
        });
      }
    }

    console.log(`Resultado: ${registros.length} registros`);
    
    // ORDENAR por data mais recente
    registros.sort((a, b) => {
      try {
        const dataA = new Date(a.dataRegistro);
        const dataB = new Date(b.dataRegistro);
        return dataB - dataA;
      } catch (e) {
        return 0;
      }
    });
    
    return registros; // SEMPRE retorna array (pode ser vazio)
    
  } catch (error) {
    console.error('Erro na busca:', error);
    return []; // SEMPRE retorna array, mesmo em erro
  }
}

// FUNÇÃO PARA NORMALIZAR - trata números, texto, etc.
function normalizarParaBusca(prontuario) {
  if (prontuario === null || prontuario === undefined || prontuario === '') {
    return '';
  }
  
  // Converter para string e limpar
  return String(prontuario)
    .toString()
    .trim()
    .toLowerCase()
    .replace(/\s+/g, '') // Remove espaços
    .replace(/[^a-zA-Z0-9]/g, ''); // Remove caracteres especiais
}

// FUNÇÃO DE COMPARAÇÃO FLEXÍVEL
function compararProntuarios(prontPlanilha, prontBusca) {
  // Se ambos estão vazios, não considera
  if (!prontPlanilha && !prontBusca) return false;
  
  // Comparação exata
  if (prontPlanilha === prontBusca) return true;
  
  // Busca parcial (se o da planilha contém o buscado)
  if (prontPlanilha.includes(prontBusca)) return true;
  
  // Busca parcial inversa (se o buscado contém o da planilha)
  if (prontBusca.includes(prontPlanilha)) return true;
  
  return false;
}

